<mujoco model="dead_chick">
  <asset>
    <!-- chick_crouching mesh를 재사용 (앉아있는 자세 = 사체) -->
    <mesh name="dead_chick_vis" file="Chick_crouching.stl" scale="0.00124 0.00124 0.00124"/>
    <mesh name="dead_chick_col" file="Chick_crouching.stl" scale="0.00124 0.00124 0.00124" maxhullvert="64"/>
    <!-- IR 타겟(죽은) 개체: thermal_fx 컬러맵에서 26~31°C(보라~자홍) 대역으로 매핑되도록
         중간 밝기 albedo. 차가운 배경(팔/바닥/바구니)보다 밝아 또렷한 blob으로 보임.
         (컬러맵은 hue를 버리고 밝기만 쓰므로 rgba hue 자체는 최종색과 무관) -->
    <material name="dead_chick_mat" rgba="0.40 0.42 0.50 1.0" emission="0.12" specular="0.0" shininess="0.0"/>
  </asset>

  <!-- VLA가 metadata로 읽을 수 있는 온도 태그.
       살아있는 닭: ~41°C, 사체: 주변 온도(~20°C). -->
  <custom>
    <numeric name="body_temperature_celsius" data="20.0"/>
    <numeric name="is_alive" data="0"/>
  </custom>

  <worldbody>
    <body>
      <body name="object">
        <!-- 사체는 무게중심 그대로 (서 있을 필요 없음). 회전 관성도 작게 → 잡으면 잘 굴러감 -->
        <inertial pos="0 0 0.012" mass="0.1" diaginertia="5e-5 5e-5 5e-5"/>

        <geom type="mesh" mesh="dead_chick_vis" material="dead_chick_mat"
              friction="1.2 0.3 0.05"
              conaffinity="0" contype="0" group="1"/>

        <!-- 그리퍼가 안정적으로 잡을 수 있게 단순 primitive collision (mesh보다 훨씬 robust).
             높이 5cm × 반지름 ~2.5cm의 캡슐 — 그리퍼 사이에 들어맞는 크기.
             높은 friction으로 한번 잡으면 안 미끄러짐. -->
        <geom type="capsule" size="0.022 0.015" pos="0 0 0.020"
              density="0" friction="2.0 0.5 0.1"
              solimp="0.95 0.99 0.001 0.5 2" solref="0.01 1"
              group="0" rgba="0.8 0.8 0.8 0"/>
      </body>
      <site rgba="0 0 0 0" size="0.005" pos="0 0 0"          name="bottom_site"/>
      <site rgba="0 0 0 0" size="0.005" pos="0 0 0.070"      name="top_site"/>
      <site rgba="0 0 0 0" size="0.005" pos="0.030 0.030 0"  name="horizontal_radius_site"/>
    </body>
  </worldbody>
</mujoco>
